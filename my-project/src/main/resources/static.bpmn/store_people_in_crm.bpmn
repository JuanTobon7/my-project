    <bpmn:serviceTask id="Activity_1mti2xd" name="Notificar Registro">
      <bpmn:extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="method">POST</camunda:inputParameter>
            <camunda:inputParameter name="payload">
              <camunda:script scriptFormat="Groovy">import groovy.json.JsonOutput
JsonOutput.toJson([
  personName:     execution.getVariable("personName"),
  personLastName: execution.getVariable("personLastName"),
  numberPhone:    execution.getVariable("numberPhone"),
  email:          execution.getVariable("email")
])</camunda:script>
            </camunda:inputParameter>
            <camunda:inputParameter name="headers">
              <camunda:map>
                <camunda:entry key="Content-Type">application/json</camunda:entry>
              </camunda:map>
            </camunda:inputParameter>
            <camunda:inputParameter name="url">http://localhost:8080/client/register/notify</camunda:inputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>http-connector</camunda:connectorId>
        </camunda:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1aj2zbt</bpmn:incoming>
      <bpmn:outgoing>Flow_1svz6y7</bpmn:outgoing>
